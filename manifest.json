{
  "manifest_version": 3,
  "name": "Smart Fill - NSR LossControl360",
  "version": "4.0.0",
  "description": "AI-assisted form review + image extraction for LossControl360. Side-panel UI with Accept/Reject workflow for forms and API-verified label sorting for survey photos.",

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "sidePanel",
    "tabs"
  ],

  "host_permissions": [
    "https://natsr.losscontrol360.com/*",
    "*://*.losscontrol360.com/*",
    "https://qagent.dhaninfo.ai/*",
    "http://164.52.196.182/*"
  ],

  "action": {
    "default_title": "Open Smart Fill",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },

  "background": {
    "service_worker": "background/background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://natsr.losscontrol360.com/*"],
      "js": [
        "common/forms.js",
        "content/extractor.js",
        "content/writer.js",
        "content/highlighter.js",
        "content/images.js",
        "content/imageModal.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.losscontrol360.com/pages/cases/*"],
      "js": [
        "common/forms.js",
        "content/images.js",
        "content/imageModal.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
